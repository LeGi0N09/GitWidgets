{
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.+)",
            "destination": "/api/index.js"
        }
    ],
    "redirects": [
        {
            "source": "/",
            "destination": "https://github.com/LeGi0N9/GitWidgets"
        }
    ],
    "cleanUrls": true
}
