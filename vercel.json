{
    "version": 2,
    "builds": [
        {
            "src": "api/index.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "https://github.com/LeGi0N09/GitWidgets",
            "status": 302
        },
        {
            "src": "/api/(.*)",
            "dest": "api/index.ts"
        }
    ],
    "cleanUrls": true
}
